{
  "name": "ha-branding-overrides",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build_plugin.mjs",
    "check": "node --check src/ha-branding-overrides.js && node --check dist/ha-branding-overrides.js",
    "test:dist": "node tests/validate-dist.mjs",
    "test:unit": "vitest run",
    "test:coverage": "npm run test:dist && vitest run --coverage",
    "test": "npm run test:dist && npm run test:unit",
    "validate": "npm run build && npm run check && npm test"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  }
}
